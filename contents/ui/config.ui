<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>AutoTileConfig</class>
    <widget class="QWidget" name="AutoTileConfig">
        <property name="geometry">
            <rect>
                <x>0</x>
                <y>0</y>
                <width>480</width>
                <height>520</height>
            </rect>
        </property>
        <layout class="QVBoxLayout" name="mainLayout">
            <!-- Enable toggle -->
            <item>
                <widget class="QCheckBox" name="kcfg_enabled">
                    <property name="text">
                        <string>Enable auto-tiling</string>
                    </property>
                </widget>
            </item>

            <!-- Columns group -->
            <item>
                <widget class="QGroupBox" name="columnsGroup">
                    <property name="title">
                        <string>Columns</string>
                    </property>
                    <layout class="QFormLayout" name="columnsLayout">
                        <item row="0" column="0">
                            <widget class="QLabel" name="maxVisibleLabel">
                                <property name="text">
                                    <string>Maximum visible columns:</string>
                                </property>
                            </widget>
                        </item>
                        <item row="0" column="1">
                            <widget class="QSpinBox" name="kcfg_maxVisible">
                                <property name="minimum">
                                    <number>1</number>
                                </property>
                                <property name="maximum">
                                    <number>8</number>
                                </property>
                                <property name="value">
                                    <number>4</number>
                                </property>
                            </widget>
                        </item>
                        <item row="1" column="0">
                            <widget class="QLabel" name="gapSizeLabel">
                                <property name="text">
                                    <string>Gap between windows (px):</string>
                                </property>
                            </widget>
                        </item>
                        <item row="1" column="1">
                            <widget class="QSpinBox" name="kcfg_gapSize">
                                <property name="minimum">
                                    <number>0</number>
                                </property>
                                <property name="maximum">
                                    <number>32</number>
                                </property>
                                <property name="value">
                                    <number>8</number>
                                </property>
                                <property name="suffix">
                                    <string> px</string>
                                </property>
                            </widget>
                        </item>
                    </layout>
                </widget>
            </item>

            <!-- Performance group -->
            <item>
                <widget class="QGroupBox" name="performanceGroup">
                    <property name="title">
                        <string>Performance</string>
                    </property>
                    <layout class="QFormLayout" name="performanceLayout">
                        <item row="0" column="0">
                            <widget class="QLabel" name="debounceMsLabel">
                                <property name="text">
                                    <string>Debounce delay (ms):</string>
                                </property>
                            </widget>
                        </item>
                        <item row="0" column="1">
                            <widget class="QSpinBox" name="kcfg_debounceMs">
                                <property name="minimum">
                                    <number>50</number>
                                </property>
                                <property name="maximum">
                                    <number>1000</number>
                                </property>
                                <property name="value">
                                    <number>300</number>
                                </property>
                                <property name="singleStep">
                                    <number>50</number>
                                </property>
                                <property name="suffix">
                                    <string> ms</string>
                                </property>
                            </widget>
                        </item>
                        <item row="1" column="0">
                            <widget class="QLabel" name="maxEventsLabel">
                                <property name="text">
                                    <string>Max events per second:</string>
                                </property>
                            </widget>
                        </item>
                        <item row="1" column="1">
                            <widget class="QSpinBox" name="kcfg_maxEventsPerSecond">
                                <property name="minimum">
                                    <number>5</number>
                                </property>
                                <property name="maximum">
                                    <number>50</number>
                                </property>
                                <property name="value">
                                    <number>20</number>
                                </property>
                            </widget>
                        </item>
                    </layout>
                </widget>
            </item>

            <!-- Behavior group -->
            <item>
                <widget class="QGroupBox" name="behaviorGroup">
                    <property name="title">
                        <string>Behavior</string>
                    </property>
                    <layout class="QVBoxLayout" name="behaviorLayout">
                        <item>
                            <widget class="QCheckBox" name="kcfg_respectMinimized">
                                <property name="text">
                                    <string>Exclude minimized windows from tiling</string>
                                </property>
                            </widget>
                        </item>
                    </layout>
                </widget>
            </item>

            <!-- Filter group -->
            <item>
                <widget class="QGroupBox" name="filterGroup">
                    <property name="title">
                        <string>Excluded Window Classes</string>
                    </property>
                    <layout class="QVBoxLayout" name="filterLayout">
                        <item>
                            <widget class="QLabel" name="filterHint">
                                <property name="text">
                                    <string>Comma-separated window classes (e.g. plasmashell, krunner)</string>
                                </property>
                                <property name="wordWrap">
                                    <bool>true</bool>
                                </property>
                            </widget>
                        </item>
                        <item>
                            <widget class="QLineEdit" name="kcfg_filterByClass">
                                <property name="placeholderText">
                                    <string>plasmashell, krunner, yakuake</string>
                                </property>
                            </widget>
                        </item>
                    </layout>
                </widget>
            </item>

            <!-- Spacer -->
            <item>
                <spacer name="verticalSpacer">
                    <property name="orientation">
                        <enum>Qt::Vertical</enum>
                    </property>
                </spacer>
            </item>
        </layout>
    </widget>
</ui>
